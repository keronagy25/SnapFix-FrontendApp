{
  "expo": {
    "name": "SnapFix",
    "slug": "snapfix",
    "version": "1.0.0",
    "scheme": "snapfix",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "web": {
      "bundler": "metro",
      "output":  "single",
      "favicon": "./assets/favicon.png"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.snapfix.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1E3A8A"
      },
      "package": "com.snapfix.app"
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      [
        "expo-image-picker",
        {
          "photosPermission": "SnapFix needs access to upload documents.",
          "cameraPermission":  "SnapFix needs camera access."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}